{
  "uid": "semantic-cache",
  "title": "Semantic LLM Cache",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Cache hit rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(semantic_cache_requests_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(semantic_cache_requests_total[5m])), 1e-9)",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "id": 2,
      "title": "Estimated cost saved (USD)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "semantic_cache_cost_saved_usd_total",
          "legendFormat": "saved"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requests/sec by result",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (result) (rate(semantic_cache_requests_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Latency P95 by result (cached vs uncached)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, result) (rate(semantic_cache_request_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{result}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le, result) (rate(semantic_cache_request_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{result}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Similarity score (P50 / P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "none", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(semantic_cache_similarity_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(semantic_cache_similarity_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 6,
      "title": "Near-misses/sec",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(semantic_cache_near_miss_total[5m])",
          "legendFormat": "near misses"
        }
      ]
    }
  ]
}
