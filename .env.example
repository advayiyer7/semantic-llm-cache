# Copy this file to `.env` and fill in YOUR OWN keys.
# `.env` is git-ignored. NEVER commit real keys. NEVER paste keys into chat.

# --- Providers ---
OPENAI_API_KEY=sk-your-new-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-new-anthropic-key-here
OLLAMA_BASE_URL=http://localhost:11434

# --- Redis (vector store + cache) ---
REDIS_URL=redis://localhost:6379

# --- Embeddings ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Cache policy ---
SIMILARITY_THRESHOLD=0.95
DEFAULT_TTL_SECONDS=3600

# --- Admin / ops ---
# When set, /admin/* endpoints require this value in the X-Admin-Key header.
ADMIN_API_KEY=
# When set, /metrics requires `Authorization: Bearer <token>`.
METRICS_AUTH_TOKEN=
# Grafana admin password — REQUIRED, set a strong value before starting Grafana.
GRAFANA_ADMIN_PASSWORD=
